// HÀM TỰ ĐỘNG HIGHLIGHT MENU
function activeMenu() {
    // 1. Lấy tên file hiện tại trên thanh địa chỉ (VD: index.html)
    const currentPath = window.location.pathname.split("/").pop();
    
    // 2. Tìm tất cả các link trong menu
    const navLinks = document.querySelectorAll(".main-nav a");

    navLinks.forEach(link => {
        // Lấy tên file trong thuộc tính href của mỗi thẻ <a>
        const linkPath = link.getAttribute("href");

        // 3. Nếu tên file khớp nhau thì thêm class 'active'
        if (currentPath === linkPath) {
            link.classList.add("active");
        }
        
        // Trường hợp đặc biệt: Nếu trang chủ để trống thì mặc định là index.html
        if (currentPath === "" && linkPath === "index.html") {
            link.classList.add("active");
        }
    });
}

// Chạy hàm ngay khi trang web vừa tải xong
document.addEventListener("DOMContentLoaded", activeMenu);


// 4. ĐIỀU KHIỂN SLIDESHOW (BANNER TỰ ĐỘNG)
let slideIndex = 0;

function showSlides() {
    const slides = document.querySelectorAll(".mySlides");
    const track = document.querySelector(".slides-track");
    
    // Nếu không tìm thấy slide (trường hợp ở các trang không phải trang chủ) thì thoát
    if (!slides.length || !track) return;

    slideIndex++;
    if (slideIndex >= slides.length) {
        slideIndex = 0;
    }

    // Di chuyển thanh chứa ảnh
    track.style.transform = `translateX(-${slideIndex * 100}%)`;
}

// Thiết lập 3 giây đổi ảnh 1 lần (3000ms)
setInterval(showSlides, 3000);