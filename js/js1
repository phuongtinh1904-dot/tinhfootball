// 2. HÀM TÌM KIẾM TRỰC TIẾP (LIVE SEARCH)
// ==========================================
function showLiveResults(query) {
    const dropdown = document.getElementById('live-search-results');
    console.log("Đang gõ từ khóa:", query);

    if (!query.trim()) {
        dropdown.style.display = "none";
        return;
    }

    // Lọc sản phẩm
    const match = allProducts.filter(p => p.name.toLowerCase().includes(query.toLowerCase()));
    console.log("Tìm thấy:", match.length, "sản phẩm");

    if (match.length > 0) {
        dropdown.innerHTML = match.map(p => `
            <a href="${p.link}" style="display: flex; align-items: center; padding: 10px; border-bottom: 1px solid #eee; text-decoration: none; color: black;">
                <img src="${p.img}" style="width: 40px; height: 40px; margin-right: 10px; object-fit: contain;">
                <div>
                    <div style="font-weight: bold; font-size: 14px;">${p.name}</div>
                    <div style="color: red; font-size: 12px;">${p.price}</div>
                </div>
            </a>
        `).join('');
        dropdown.style.display = "block";
    } else {
        dropdown.innerHTML = '<div style="padding: 10px; font-size: 13px;">Không tìm thấy sản phẩm...</div>';
        dropdown.style.display = "block";
    }
}

