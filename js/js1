// 3. CÁC HÀM GIỎ HÀNG (CŨ)
// ==========================================
function changeQty(amount) {
    const qtyInput = document.getElementById('quantity');
    if (qtyInput) {
        let val = parseInt(qtyInput.value) || 1;
        val += amount;
        if (val < 1) val = 1;
        qtyInput.value = val;
    }
}

function selectSize(btn) {
    document.querySelectorAll('.size-item').forEach(item => item.classList.remove('active'));
    btn.classList.add('active');
}

function addToItemToStorage() {
    const selectedSizeBtn = document.querySelector('.size-item.active'); 
    if (!selectedSizeBtn) {
        alert('Vui lòng chọn size trước khi mua hàng!');
        return false;
    }
    const name = document.querySelector('.detail-title').innerText;
    const price = document.querySelector('.curr-price').innerText;
    const img = document.querySelector('#main-product-img').src;
    const qty = parseInt(document.getElementById('quantity').value) || 1;
    const size = selectedSizeBtn.innerText;

    const product = { name: name, price: price, image: img, quantity: qty, size: size };
    let cart = JSON.parse(localStorage.getItem('cart')) || [];
    const idx = cart.findIndex(item => item.name === product.name && item.size === product.size);
    if (idx > -1) cart[idx].quantity += qty;
    else cart.push(product);
    localStorage.setItem('cart', JSON.stringify(cart));
    return true;
}

function addToCart() {
    if (addToItemToStorage()) {
        updateCartCount();
        alert('Đã thêm sản phẩm vào giỏ hàng!');
    }
}

function buyNow() {
    if (addToItemToStorage()) window.location.href = 'checkout.html';
}

function updateCartCount() {
    const countElement = document.getElementById('cart-count');
    if (countElement) {
        let cart = JSON.parse(localStorage.getItem('cart')) || [];
        const total = cart.reduce((sum, item) => sum + item.quantity, 0);
        countElement.innerText = total;
    }
}

window.onload = updateCartCount;

