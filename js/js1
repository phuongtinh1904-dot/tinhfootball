
// 1. XỬ LÝ SỐ LƯỢNG (NÚT + VÀ -)
function changeQty(amount) {
    const qtyInput = document.getElementById('quantity');
    if (qtyInput) {
        let currentQty = parseInt(qtyInput.value) || 1;
        currentQty += amount;
        // Đảm bảo số lượng không nhỏ hơn 1
        if (currentQty < 1) currentQty = 1;
        qtyInput.value = currentQty;
    }
}

// 2. XỬ LÝ CHỌN SIZE
function selectSize(btn) {
    // Xóa class 'active' của tất cả các nút size
    const allSizes = document.querySelectorAll('.size-item');
    allSizes.forEach(item => item.classList.remove('active'));
    
    // Thêm class 'active' cho nút vừa được bấm
    btn.classList.add('active');
}

// 3. LOGIC LƯU DỮ LIỆU (Dùng chung cho Add to Cart & Buy Now)
function addToItemToStorage() {
    // Kiểm tra xem đã chọn size chưa
    const selectedSizeBtn = document.querySelector('.size-item.active'); 
    if (!selectedSizeBtn) {
        alert('Vui lòng chọn size trước khi mua hàng!');
        return false; // Trả về false để dừng các hàm phía sau
    }

    // Lấy thông tin từ giao diện
    const nameNode = document.querySelector('.detail-title');
    const priceNode = document.querySelector('.curr-price');
    const imgNode = document.querySelector('#main-product-img');
    const qtyNode = document.getElementById('quantity');

    // Nếu thiếu thông tin cơ bản thì báo lỗi
    if (!nameNode || !priceNode) {
        console.error("Không tìm thấy thông tin sản phẩm (class .detail-title hoặc .curr-price)");
        return false;
    }

    const productName = nameNode.innerText;
    const productPrice = priceNode.innerText;
    const productImg = imgNode ? imgNode.src : "";
    const quantity = qtyNode ? parseInt(qtyNode.value) : 1;
    const size = selectedSizeBtn.innerText;

    // Tạo đối tượng sản phẩm
    const product = { 
        name: productName, 
        price: productPrice, 
        image: productImg, 
        quantity: quantity, 
        size: size 
    };
    
    // Lấy giỏ hàng từ LocalStorage
    let cart = JSON.parse(localStorage.getItem('cart')) || [];
    
    // Kiểm tra xem sản phẩm đã có trong giỏ chưa (cùng tên và cùng size)
    const existingIdx = cart.findIndex(item => item.name === product.name && item.size === product.size);
    
    if (existingIdx > -1) {
        // Nếu có rồi thì tăng số lượng
        cart[existingIdx].quantity += quantity;
    } else {
        // Nếu chưa có thì thêm mới
        cart.push(product);
    }
    
    // Lưu ngược lại vào LocalStorage
    localStorage.setItem('cart', JSON.stringify(cart));
    return true; // Trả về true báo hiệu thành công
}

// 4. NÚT THÊM VÀO GIỎ HÀNG
function addToCart() {
    if (addToItemToStorage()) {
        updateCartCount(); // Cập nhật số trên icon giỏ hàng
        alert('Đã thêm sản phẩm vào giỏ hàng của TINH FOOTBALL!');
    }
}

// 5. NÚT MUA NGAY
function buyNow() {
    if (addToItemToStorage()) {
        // Nếu lưu thành công (đã chọn size) thì nhảy trang
        window.location.href = 'checkout.html';
    }
}
// 6. CẬP NHẬT SỐ LƯỢNG TRÊN ICON HEADER
function updateCartCount() {
    const countElement = document.getElementById('cart-count');
    if (countElement) {
        let cart = JSON.parse(localStorage.getItem('cart')) || [];
        // Tính tổng số lượng tất cả sản phẩm
        const totalItems = cart.reduce((sum, item) => sum + item.quantity, 0);
        countElement.innerText = totalItems;
    }
}

// Chạy hàm cập nhật số lượng mỗi khi load trang bất kỳ
document.addEventListener('DOMContentLoaded', updateCartCount);



